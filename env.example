# Motion API Configuration
# Get your API key from: https://www.usemotion.com/settings/api
MOTION_API_KEY=your_motion_api_key_here

# Get your workspace ID from Motion dashboard
MOTION_WORKSPACE_ID=your_motion_workspace_id_here

# OpenAI API Configuration (required for notes → tasks conversion)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Triage project ID to use when task project inference has low confidence
# The system will automatically search for a project with "triage" in the name,
# but you can also explicitly set it here. Takes precedence over DEFAULT_PROJECT_ID.
# Example: TRIAGE_PROJECT_ID=pr_QQcNa5wK9KHgFMvoqRQSHc
# TRIAGE_PROJECT_ID=

# Optional: Default project ID to use when task project inference has low confidence
# Only used if no triage project is found (either by name or TRIAGE_PROJECT_ID)
# If not set, tasks with low confidence matches will fail
# Example: DEFAULT_PROJECT_ID=pr_QQcNa5wK9KHgFMvoqRQSHc
# DEFAULT_PROJECT_ID=

# Optional: Name override for the Motion project that holds block tasks
# CLOCKWISE_PROJECT_NAME=Clockwise Blocks

# Google Calendar Integration (required for block-time)
# 1. Go to https://console.cloud.google.com/ and create a project
# 2. Enable the Google Calendar API
# 3. Create OAuth 2.0 credentials (Desktop app type)
# 4. Copy the client ID and secret here, then run: npm run block-time:setup-auth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Set automatically by `npm run block-time:setup-auth` — do not edit manually
# GOOGLE_REFRESH_TOKEN=

# Optional: Set to 'true' to enable debug logging
DEBUG=false
